# Configuração do exemplo consumidor da API externa do G4.
# Copie para `.env` (este arquivo .env é ignorado pelo git).

# Base do backend do G4 - Consultas.
API_BASE_URL=http://localhost:3000

# Chave de API emitida pelo G4 (gerada na tela Admin -> API Keys, ou via API).
# Formato: g4_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY=cole_sua_chave_aqui

# Paciente usado nos exemplos.
PATIENT_ID=p1
