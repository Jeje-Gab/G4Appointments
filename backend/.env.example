# ===== HTTP server =====
PORT=3000

# ===== PostgreSQL =====
# Either set DATABASE_URL or the individual PG* variables below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/g4_consultations
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=g4_consultations

# ===== External modules =====
# G1 - Patients
PATIENTS_API_BASE_URL=https://pacientes-1a6g.onrender.com
TOKEN_G1=
# G3 - Schedule (módulo interno, pasta schedule/ deste repo)
SCHEDULE_API_BASE_URL=http://localhost:3002

# Timeout (ms) for external HTTP calls
EXTERNAL_HTTP_TIMEOUT_MS=5000
# Timeout maior para o G1 (Render free tier pode demorar ~50s para acordar)
PATIENTS_HTTP_TIMEOUT_MS=60000

# ===== Development mocks =====
# USE_MOCK_GATEWAYS=true desliga todos os mocks de uma vez.
# Para controle individual use as variáveis abaixo:
USE_MOCK_GATEWAYS=false
USE_MOCK_PATIENTS=false
USE_MOCK_SCHEDULE=false

# ===== Auth =====
# Lifetime (hours) of a login session token (admin and user roles).
SESSION_TTL_HOURS=12
